local DefaultProperties = {
	BorderSizePixel = 0,
	BackgroundColor3 = Color3.fromRGB(0, 55, 75),
	FontFace = Font.fromName("Sarpanch"),
	TextColor3 = Color3.fromRGB(255, 255, 255),
	TextScaled = true,
	ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
	StrokeSizingMode = Enum.StrokeSizingMode.ScaledSize,
	ScrollBarThickness = 0,
	ScrollBarImageTransparency = 1
}

function LoadInstance(InstanceToLoad, InstanceParent)
	for Name, Properties in InstanceToLoad do
		if InstanceParent:FindFirstChild(Name) then
			InstanceParent[Name]:Destroy()
		end
		
		local NewInstance = Instance.new(Properties.ClassName)
		NewInstance.Name = Name
		
		if NewInstance.ClassName == "ScreenGui" then
			NewInstance.Enabled = false
		end
		
		for DefaultProperty, Value in DefaultProperties do
			local HasProperty, _ = pcall(function()
				NewInstance[DefaultProperty] = NewInstance[DefaultProperty]
			end)

			if HasProperty and Properties[DefaultProperty] == nil then
				if DefaultProperty ~= "BackgroundColor3" or (DefaultProperty == "BackgroundColor3" and NewInstance.BackgroundTransparency < 1) then
					NewInstance[DefaultProperty] = Value
				end
			end
		end
		
		for Property, Value in Properties do
			if Property == "Files" then
				LoadInstance(Value, NewInstance)
			elseif Property == "Tags" then
				for _, TagName in Value do
					NewInstance:AddTag(TagName)
				end
			elseif Property == "Attributes" then
				for AttributeName, AttributeValue in Value do
					NewInstance:SetAttribute(AttributeName, AttributeValue)
				end
			else
				if Property ~= "ClassName" then
					NewInstance[Property] = Value
				end
			end
		end
		
		NewInstance.Parent = InstanceParent
	end
end

