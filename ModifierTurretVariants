function CreateCustomTurret(TurretOriginalPart, TurretRoom, Info)
	if TurretOriginalPart == nil then
		return print("CreateCustomTurrer No TurretOriginalPart")
	end
	
	if TurretRoom == nil then
		return print("CreateCustomTurrer No TurretRoom")
	end
	
	local TurretInfo = {
		Variant = "Default",
		PowerVariant = "Default",
		
		Anim = {},
		Color = {}
	}
	
	if Info then
		for Property, Value in TurretInfo do
			if Info[Property] then
				TurretInfo[Property] = Info[Property]
			end
		end
	end
	
	if TurretVariantsInfo[TurretInfo.Variant] == nil then
		return print("CreateCustomTurret No Info For Variant: "..TurretInfo.Variant)
	end
	
	TurretCount += 1
	
	for _, BehaviorInfo in {"FireRate", "MaxMagazines", "MaxBullets", "BulletSpread", "SearchSpeedTime", "MaxUp", "MaxDown", "MaxLeft", "MaxRight"} do
		if TurretVariantsInfo[TurretInfo.Variant][TurretInfo.PowerVariant][BehaviorInfo] then
			TurretInfo[BehaviorInfo] = TurretVariantsInfo[TurretInfo.Variant][TurretInfo.PowerVariant][BehaviorInfo]
		else
			TurretInfo[BehaviorInfo] = TurretVariantsInfo.Default[TurretInfo.PowerVariant][BehaviorInfo]
		end
	end
	
	local Turret = game.ReplicatedStorage.Assets.Turret:Clone()
	Turret:PivotTo(TurretOriginalPart.CFrame)
	Turret.Parent = TurretRoom:FindFirstChild("Interactables") or TurretRoom
	
	Turret:SetAttribute("CustomMade", true)
	Turret:SetAttribute("Disabled", false)
	
	if game.ReplicatedStorage.GameSettings.Modifier:FindFirstChild("TurretUpgrades") then
		Turret:SetAttribute("BeamsDisabled", true)
	end
	
	TurretOriginalPart:SetAttribute("CustomChecked", true)
	Instance.new("ObjectValue", Turret).Name = "ShootReal"
	
	if TurretOriginalPart:FindFirstChild("Shoot") then
		Turret.ShootReal.Value = TurretOriginalPart.Shoot
	else
		TurretOriginalPart.ChildAdded:Connect(function(Child)
			if Child.Name == "Shoot" and Child:IsA("UnreliableRemoteEvent") then
				Turret.ShootReal.Value = Child
			end
		end)
	end
	
	for Property, Value in TurretInfo do
		if type(Value) ~= "table" then
			Turret:SetAttribute(Property, Value)
			
			if Property == "MaxMagazines" then
				Turret:SetAttribute("MagazinesLeft", Value)
			end
		end
	end
	
	for ColorName, ColorValue in TurretVariantsInfo.Default[TurretInfo.PowerVariant].Color do
		TurretInfo.Color[ColorName] = TurretVariantsInfo[TurretInfo.Variant][TurretInfo.PowerVariant].Color[ColorName] or ColorValue
	end
	
	for _, Anim in game.ReplicatedStorage.Interactions.Turret.Animations:GetChildren() do
		TurretInfo.Anim[Anim.Name] = Turret.AnimationController.Animator:LoadAnimation(Anim)
	end
	
	game.ReplicatedStorage.Interactions.Turret.Sounds.TurretReload:Clone().Parent = Turret
	
	TurretInfo.Anim.OffIdle:Play()
	
