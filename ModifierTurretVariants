							if PlayerMain.LockerState or not ObjectRaycast.Instance:IsDescendantOf(game.Players.LocalPlayer.Character) then
								if ObjectRaycast.Instance:IsDescendantOf(game.Workspace.GameplayFolder.Monsters) then
									local DetectedMonster = nil

									for _, Monster in pairs(workspace.GameplayFolder.Monsters:GetChildren()) do
										if ObjectRaycast.Instance:IsDescendantOf(Monster) then
											DetectedMonster = Monster
										end
									end
									
									if not DetectedMonster:GetAttribute("Dead") and Turret.ShootReal.Value then
										DetectedMonster:SetAttribute("Dead", true)
										Turret.ShootReal.Value:FireServer(DetectedMonster)
									end
								end
							else
								if TurretInfo.Variant == "Default" then
									game.ReplicatedStorage.Events.LocalDamage:FireServer(15, "DefenseSystem", 1, nil, nil, nil)
								elseif TurretInfo.Variant == "VoidTurret" then
									game.ReplicatedStorage.Events.LocalDamage:FireServer(3, "DefenseSystem", 1, nil, nil, nil, 10)
								end
							end
						elseif ObjectRaycast.Material == Enum.Material.Metal then
							HitSound = TurretSounds[TurretInfo.Variant].AllImpactMetalSounds[math.random(1, #TurretSounds[TurretInfo.Variant].AllImpactMetalSounds)]:Clone()
							Bullet.MetalHit:Emit(Bullet.MetalHit.Rate)
						else
							HitSound = TurretSounds[TurretInfo.Variant].AllImpactGeneralSounds[math.random(1, #TurretSounds[TurretInfo.Variant].AllImpactGeneralSounds)]:Clone()
							Bullet.Debris:Emit(Bullet.Debris.Rate)
						end
						
						HitSound.Parent = Bullet
						HitSound:Play()
						
						if Bullet.Decal.Transparency ~= 1 then
							game.TweenService:Create(Bullet.Decal, TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 4), {
								Transparency = 1
							}):Play()
						end
						
						game.Debris:AddItem(Bullet, 5)
					end
					if PlayerMain.PlayerDead or PlayerMain.IsGhost or not game.Players.LocalPlayer.Character:FindFirstChild("Head") then
						return
					end
					
					if not ((ObjectRaycast.Position - game.Players.LocalPlayer.Character.Head.Position).Magnitude < 10) then
						return
					end
					
					PlayerMain.SpecialLocalEffects.Effects.TurretBullet()
				end)
			end)
		end
	end
	
	local function TurretDesiredLocationShoot(Info)
		if Info == nil then
			return
		end

		if (Turret:GetAttribute("MagazinesLeft") <= 0 and not game.ReplicatedStorage.GameSettings.Modifier:FindFirstChild("TurretUpgrades")) or not Turret:GetAttribute("Active") or Turret.Target.Value and Info.PlayerMain == nil or Info.Target == nil then
			return
		end

		if Info.Target:IsA("Model") then
			Turret.Target.Value = Info.Target.PrimaryPart or Info.Target
		elseif Info.Target == game.Players.LocalPlayer and not Info.PlayerMain.PainterDead then
			Turret.Target.Value = game.Players.LocalPlayer.Character.HumanoidRootPart
		end

		Turret:SetAttribute("Shooting", true)
		Turret:SetAttribute("MagazinesLeft", Turret:GetAttribute("MagazinesLeft") - 1)

		task.wait(0.6)

		for i = 1, Turret:GetAttribute("MaxBullets") do
			TurretShoot()

			task.wait(1 / Turret:GetAttribute("FireRate"))
		end
		Turret:SetAttribute("Shooting", false)

		task.wait(0.5)

		Turret.Target.Value = nil
		
		if Turret:GetAttribute("MagazinesLeft") <= 0 and not game.ReplicatedStorage.GameSettings.Modifier:FindFirstChild("TurretUpgrades") then
			Turret:SetAttribute("Active", false)

			task.wait(3)

			Turret.TurretReload:Play()

			task.wait(4)
			
			Turret:SetAttribute("MagazinesLeft", Turret:GetAttribute("MaxMagazines"))
			
			if Turret:GetAttribute("PlayerInRoom") and not Turret:GetAttribute("Disabled") then
				Turret:SetAttribute("Active", true)
			end
		end
	end
	
	local v35 = nil
	local v36 = nil
	
	local function TurretDesiredLocationIdle(p1, p2)
		if not Turret:GetAttribute("Active") then
			return
		end
		
		if TurretAimBaseJoint_2 then
			TurretAimBaseJoint_2:Pause()
			TurretAimBaseJoint_2 = nil
		end
		if TurretAimPivot then
			TurretAimPivot:Pause()
			TurretAimPivot = nil
		end
		
		if (v35 ~= p1 or v36 ~= p2) and not TurretMovingLoopSound.Playing then
			TurretMovingLoopSound:Play()
		end
		local v1 = math.rad(p1)
		local v2 = math.rad(p2)
		v35 = v1
		v36 = v2
		TurretAimBaseJoint_2 = game.TweenService:Create(BaseJoint_2, TweenInfo.new(Turret:GetAttribute("SearchSpeedTime"), Enum.EasingStyle.Linear), {
			C1 = CFrame.new(-0.02, 0, 0) * CFrame.Angles(0, v2, 0)
		})
		TurretAimPivot = game.TweenService:Create(Pivot, TweenInfo.new(Turret:GetAttribute("SearchSpeedTime"), Enum.EasingStyle.Linear), {
			C1 = CFrame.new(0.5, 0.5, 0.75) * CFrame.Angles(v1, 0, 0)
		})
		
		TurretAimBaseJoint_2:Play()
		TurretAimPivot:Play()
		
		task.wait(Turret:GetAttribute("SearchSpeedTime"))
		
		if v1 ~= v1 or v2 ~= v2 then
			return
		end
		
		TurretMovingLoopSound:Stop()
	end
	
	local Horisontal = "max"
	local v11 = "mid"

	local function StartTurret()
		Turret:SetAttribute("Active", true)
		
		while Turret:GetAttribute("Active") do
			local TurretHorisontal = nil

			if Target.Value or Turret:GetAttribute("Shooting") then
				task.wait(0.3)
			end

			local TurretVertical = math.random(Turret:GetAttribute("MaxUp"), Turret:GetAttribute("MaxDown"))
			
			if Horisontal == "max" then
				if v11 == "max" then
					TurretHorisontal = (Turret:GetAttribute("MaxLeft") + Turret:GetAttribute("Right")) / 2
					v11 = "mid"
				else
					TurretHorisontal = Turret:GetAttribute("MaxLeft")
					Horisontal = "min"
					v11 = "min"
				end
			elseif v11 == "min" then
				TurretHorisontal = (Turret:GetAttribute("MaxLeft") + Turret:GetAttribute("Right")) / 2
				v11 = "mid"
			else
				TurretHorisontal = Turret:GetAttribute("MaxRight")
				Horisontal = "max"
				v11 = "max"
			end
			
			TurretDesiredLocationIdle(TurretVertical, TurretHorisontal)
			
			if v11 == "mid" then
				task.wait(Turret:GetAttribute("SearchSpeedTime"))
			else
				task.wait(Turret:GetAttribute("SearchSpeedTime") + 1)
			end
		end
	end
	
	TurretInfo.Anim.Open:GetMarkerReachedSignal("EnableLights"):Connect(function()
		if not Turret:GetAttribute("BeamsDisabled") then
			for _, Beam in AllBeams do
				Beam.Enabled = true
			end
			BeamMesh.Transparency = 0.98
			BeamMesh.Attachment0.SpotLight.Enabled = true
			BeamMesh.Beam.Enabled = true
		end
		
		task.wait(0.5)
		
		if not Turret:GetAttribute("Active") then
			return
		end
		
		
		
		game.RunService:UnbindFromRenderStep(UniqueTurretTag)
		game.RunService:BindToRenderStep(UniqueTurretTag, 250, function()
			local DetectedPlayer = nil
			local DetectedMonster = nil
			for _, Beam in pairs(AllBeams) do
				local ObjectInRaycast = game.Workspace:Raycast(Beam.Attachment0.WorldPosition, CFrame.lookAt(Beam.Attachment0.WorldPosition, Beam.Attachment1.WorldPosition).LookVector * 200, RaycastBeam)
				if ObjectInRaycast then
					if ObjectInRaycast.Instance.Transparency > 0.8 then
						table.insert(FilterRaycast, ObjectInRaycast.Instance)
						RaycastBeam.FilterDescendantsInstances = FilterRaycast
					end
					
					Beam.Attachment1.WorldPosition = ObjectInRaycast.Position
					
					if not PlayerMain.Dead and (not PlayerMain.IsGhost and (not PlayerMain.LockerState and (not DetectedPlayer and (not Target.Value and ObjectInRaycast.Instance:IsDescendantOf(game.Players.LocalPlayer.Character))))) then
						DetectedPlayer = true
					end
					
					if ObjectInRaycast.Instance:IsDescendantOf(game.Workspace.GameplayFolder.Monsters) then
						for _, Monster in game.Workspace.GameplayFolder.Monsters:GetChildren() do
							if ObjectInRaycast.Instance:IsDescendantOf(Monster) then
								DetectedMonster = Monster
							end
						end
					end
				end
			end
			if DetectedPlayer and not TurretAttack then
				TurretAttack = true
				
				TurretDesiredLocationShoot({
					PlayerMain = PlayerMain,
					Target = game.Players.LocalPlayer
				})
				
				if game.Workspace.GameSettings.Modifier:FindFirstChild("ArtPortfolio") then
					for i = 1, math.random(1, 2) do
						PlayerMain.SpecialLocalEffects.Effects.PainterPopup("rbxassetid://74954245678736")
					end
				end
			end
			if DetectedMonster and not MonsterAttacked[DetectedMonster] then
				MonsterAttacked[DetectedMonster] = true
				
				task.delay(1, function()
					MonsterAttacked[DetectedMonster] = nil
				end)
				
				TurretDesiredLocationShoot({
					PlayerMain = PlayerMain,
					Target = DetectedMonster
				})
			end
		end)
	end)
	
	Turret:GetAttributeChangedSignal("Shooting"):Connect(function()
		if not Turret:GetAttribute("Shooting") then
			return
		end
		
		if TurretAimBaseJoint_2 then
			TurretAimBaseJoint_2:Pause()
			TurretAimBaseJoint_2 = nil
		end
		if TurretAimPivot then
			TurretAimPivot:Pause()
			TurretAimPivot = nil
		end
		
		BaseJoint.TurretAlerted:Play()
		
		if not Turret:GetAttribute("BeamsDisabled") then
			for i = 1, 5 do
				for _, Beam in AllBeams do
					Beam.Enabled = not Beam.Enabled
				end
				
				task.wait(0.1)
			end
			
			for _, Beam in AllBeams do
				Beam.Enabled = Turret:GetAttribute("Active")
			end
		end
	end)
	
	local function TurretUpdateMainPosition(NewPart)
		local v1, v2, _ = Root.CFrame:ToObjectSpace(NewPart):ToOrientation()
		local sum = v2 + math.pi
		if sum > math.pi then
			sum = sum - 6.283185307179586
		elseif sum < -3.141592653589793 then
			sum = sum + 6.283185307179586
		end
		return -v1, -sum
	end

	Target.Changed:Connect(function()
		local TurretTarget = Target.Value
		if TurretTarget == game.Players.LocalPlayer.Character.HumanoidRootPart then
			if PlayerMain.Data.GameSettings.DeafMode.Value == 1 then
				PlayerMain.SubTitles.new("A turret has locked on to me!", 4):Show()
			end
		else
			TurretAttack = false
		end
		if TurretTarget then
			game.RunService:UnbindFromRenderStep("track"..UniqueTurretTag)
			game.RunService:BindToRenderStep("track"..UniqueTurretTag, 251, function()
				local OrienX, OrienY, OrienZ = Root.CFrame:ToObjectSpace((CFrame.lookAt(BaseJoint.Position, Target.Position))):ToOrientation()
				local sum = OrienY + math.pi
				if sum > math.pi then
					sum = sum - 6.283185307179586
				elseif sum < -3.141592653589793 then
					sum = sum + 6.283185307179586
				end
				game.TweenService:Create(BaseJoint_2, TweenInfo.new(Turret:GetAttribute("TrackingSpeed"), Enum.EasingStyle.Linear), {
					C1 = CFrame.new(-0.02, 0, 0) * CFrame.Angles(0, -sum, 0)
				}):Play()
				game.TweenService:Create(Pivot, TweenInfo.new(Turret:GetAttribute("TrackingSpeed"), Enum.EasingStyle.Linear), {
					C1 = CFrame.new(0.5, 0.5, 0.75) * CFrame.Angles(-OrienX, 0, 0)
				}):Play()
			end)
		else
			game.RunService:UnbindFromRenderStep("track"..UniqueTurretTag)
		end
	end)
	
	if Turret:GetAttribute("Active") then
		ToggleActive()
		task.spawn(function()
			StartTurret()
		end)
	else
		TurretInfo.Anim.OffIdle:Play()
		for _, Beam in pairs(AllBeams) do
			Beam.Enabled = false
		end
		BeamMesh.Transparency = 1
		BeamMesh.Attachment0.SpotLight.Enabled = false
		BeamMesh.Beam.Enabled = false
	end
end

