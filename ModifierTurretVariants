							Turret:SetAttribute("Disabled", false)
						else
							Turret:SetAttribute("Disabled", true)
						end
					end
					
					Turret:SetAttribute("PlayerInRoom", PlayerZone.CurrentRoom == Room)
				end
			end
		end
	end
