local Player = game.Players.LocalPlayer
local Character = Player.Character
local CurrentCamera = game.Workspace.CurrentCamera

local GameplayFolder = game.Workspace.GameplayFolder
local RoomsFolder = GameplayFolder.Rooms

local OpenedRooms = {"Start"}
local NextUngeneratedRoom = nil
local DoorRoot = nil
local DoorRootTouched = false
local DoorRootRightVectorValue = Instance.new("IntValue")
DoorRootRightVectorValue.Value = -5

local PressureDoors = {
	["NormalDoor"] = {
		Root = "Root"
	},
	["LargeRoundDoor"] = {
		Root = "RootPart"
	}
}

local function GetNextUngeneratedRoom()
	for _, Room in pairs(RoomsFolder:GetChildren()) do
		if Room:FindFirstChild("Entrances") then
			local Doors = 0
			for _, Door in pairs(Room.Entrances:GetChildren()) do
				Doors += 1
				if Doors >= 2 then
					return print("ERROR | 2 Entrances Doors")
				end

				if Door.OpenValue.Value == false then
					NextUngeneratedRoom = Room
				end
			end
		end
	end
end

local function TeleportToDoor()
	if NextUngeneratedRoom ~= nil then
		if NextUngeneratedRoom.Parent == RoomsFolder then
			if NextUngeneratedRoom:FindFirstChild("Entrances") then
				if NextUngeneratedRoom.Entrances:FindFirstChild("NormalDoor") then
					if NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("Root") then
						if NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("CollisionPart") then
							NextUngeneratedRoom.Entrances.NormalDoor.CollisionPart.CanCollide = false
						end
						DoorRoot = NextUngeneratedRoom.Entrances.NormalDoor.Root
						DoorRoot.Transparency = 0

						Character.HumanoidRootPart.CFrame = DoorRoot.CFrame + Vector3.new(0, 1, 0)

						DoorRoot.Touched:Once(function(Part)
							if Part.Parent:FindFirstChildOfClass("Humanoid") then
								DoorRootTouched = true
								game.TweenService:Create(DoorRootRightVectorValue, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Value = 5}):Play()
							end
						end)
					end
				end
			end
		end
	end
end

RoomsFolder.ChildAdded:Connect(function(Room)
	print("New Room Spawned")
	table.insert(OpenedRooms,NextUngeneratedRoom)
	NextUngeneratedRoom = Room

	DoorRoot = nil
	DoorRootTouched = false
	DoorRootRightVectorValue.Value = -5
end)


game.UserInputService.InputBegan:Connect(function(Input)
	if Input.KeyCode == Enum.KeyCode.P then
		DoorRoot = nil
		DoorRootTouched = false
		DoorRootRightVectorValue.Value = -5
	end
end)

CurrentCamera:GetPropertyChangedSignal("CFrame"):Connect(function()
	if DoorRoot ~= nil and DoorRootTouched == true then
		DoorRoot.CFrame = CFrame.new(
				CurrentCamera.CFrame.Position
					+ (CurrentCamera.CFrame.LookVector * 4)
					+ (CurrentCamera.CFrame.RightVector * DoorRootRightVectorValue)
			) * CFrame.Angles(0, 0, 0)
	end
end)

GetNextUngeneratedRoom()
TeleportToDoor()
