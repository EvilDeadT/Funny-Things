local Main = {
	Player = game.Players.LocalPlayer,
	Character = game.Players.LocalPlayer.Character,
	CurrentCamera = game.Workspace.CurrentCamera,
	
	GameplayFolder = game.Workspace.GameplayFolder,
	RoomsFolder = game.Workspace.GameplayFolder.Rooms
}
local RoomSkip = {
	OpenedRooms = {},
	NextUngeneratedRoom = nil,
	DoorCollisionPart = nil,
	DoorRoot = nil,
	DoorRootPrompt = nil,
	
	Keycard = nil,
	Password = nil
}

function GetNextUngeneratedRoom()
	local RoomsInExitValue = {}
	for _, Room in Main.RoomsFolder:GetChildren() do
		if Room:FindFirstChild("Entrances") then
			if Room.Entrances:FindFirstChild("NormalDoor") then
				if Room.Entrances.NormalDoor:FindFirstChild("Exit") then
					local ExitRoom = Room.Entrances.NormalDoor.Exit.Value
					if ExitRoom ~= nil then
						if ExitRoom.Parent ~= nil then
							table.insert(RoomsInExitValue, ExitRoom)
						end
					end
				end
			end
		end
	end

	for _, Room in Main.RoomsFolder:GetChildren() do
		if table.find(RoomsInExitValue, Room) == nil and Room:GetAttribute("Room") then
			RoomSkip.NextUngeneratedRoom = Room
		end
	end
end

function OpenLockedRoom(LockedRoom, OpenItem, OpenItemType)
	print("Door has locked by "..OpenItemType)
	if OpenItem ~= nil then
		local Prompt = OpenItem:FindFirstChildWhichIsA("ProximityPrompt", true)
		if Prompt == nil then
			print("ERROR | "..OpenItemType.." has not ProximityPrompt in "..LockedRoom.Name)
		else
			Prompt.RequiresLineOfSight = false

			local UncollisionBox = Instance.new("Part", game.Workspace)
			UncollisionBox.Transparency = 0.5
			UncollisionBox.Anchored = true
			UncollisionBox.CanCollide = false
			UncollisionBox.CastShadow = false
			UncollisionBox.Size = Vector3.new(8, 8, 8)
			UncollisionBox.Position = OpenItem.Parent.Position

			local PartsWithCollision = {}
			for _, Part in game.Workspace:GetPartsInPart(UncollisionBox) do
				if Part.CanCollide == true and Part.Parent ~= Main.Character then
					table.insert(PartsWithCollision, Part)
					Part.CanCollide = false
				end
			end

			local TemporaryFloor = Instance.new("Part", LockedRoom)
			TemporaryFloor.Name = "TemporaryFloor"
			TemporaryFloor.Transparency = 0.5
			TemporaryFloor.Anchored = true
			TemporaryFloor.CanCollide = true
			TemporaryFloor.CastShadow = false
			TemporaryFloor.Size = Vector3.new(8, 1, 8)
			TemporaryFloor.Position = Main.Character.HumanoidRootPart.Position + Vector3.new(0, -4, 0)

			task.wait(15)

			for _, Part in PartsWithCollision do
				Part.CanCollide = true
			end
		end
	end
end

function TeleportToDoor()
	if RoomSkip.NextUngeneratedRoom ~= nil then
		if RoomSkip.NextUngeneratedRoom.Parent == Main.RoomsFolder then
			if RoomSkip.NextUngeneratedRoom:FindFirstChild("Entrances") then
				if RoomSkip.NextUngeneratedRoom.Entrances:FindFirstChild("NormalDoor") then
					if RoomSkip.NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("Root") then
						if RoomSkip.NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("CollisionPart") then
							RoomSkip.NextUngeneratedRoom.Entrances.NormalDoor.CollisionPart.CanCollide = false
						end

						RoomSkip.DoorRoot = RoomSkip.NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("Root")
						RoomSkip.DoorCollisionPart = RoomSkip.NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("CollisionPart")

						RoomSkip.Keycard = nil
						RoomSkip.Password = nil
						for _, LockedRoom in Main.RoomsFolder:GetChildren() do
							RoomSkip.Keycard = LockedRoom:FindFirstChild("NormalKeyCard", true)
							if RoomSkip.Keycard == nil then
								RoomSkip.Keycard = LockedRoom:FindFirstChild("RidgeKeyCard", true)
							end
							RoomSkip.Password = LockedRoom:FindFirstChild("PasswordPaper", true)
							if RoomSkip.Keycard ~= nil then
								--OpenLockedRoom(LockedRoom, Keycard, "Keycard")
								Main.Character.HumanoidRootPart.CFrame = RoomSkip.Keycard.NumberPart.CFrame + Vector3.new(0, 1, 0)
								break
							elseif RoomSkip.Password ~= nil then
								break
							end
						end
						if RoomSkip.Keycard == nil then
							Main.Character.HumanoidRootPart.CFrame = RoomSkip.DoorCollisionPart.CFrame + Vector3.new(0, 1, 0)
							game.ReplicatedStorage.Events.ZoneChange:FireServer(RoomSkip.NextUngeneratedRoom)

							if RoomSkip.Password == nil then
								RoomSkip.DoorRootPrompt = RoomSkip.DoorRoot:FindFirstChildWhichIsA("ProximityPrompt", true)
								if RoomSkip.DoorRootPrompt == nil then
									print("ERROR | DoorRoot has not ProximityPrompt in Entrances Door in"..RoomSkip.NextUngeneratedRoom.Name)
								end
							end
						end
					end
				end
			end
		end
	end
end

game:GetService("RunService").RenderStepped:Connect(function()
	if RoomSkip.DoorRoot ~= nil and RoomSkip.DoorRootPrompt ~= nil then
		RoomSkip.DoorRoot.CFrame = CFrame.new(
			Main.CurrentCamera.CFrame.Position + Main.CurrentCamera.CFrame.LookVector * 7
		) * CFrame.fromOrientation(0, 0, 0)
		RoomSkip.DoorRootPrompt.MaxActivationDistance = 100
		RoomSkip.DoorRootPrompt:InputHoldBegin()
		RoomSkip.DoorRootPrompt:InputHoldEnd()
	end
	if RoomSkip.NextUngeneratedRoom ~= nil and RoomSkip.Password ~= nil then
		if RoomSkip.Password.Parent ~= nil then
			if RoomSkip.Password:FindFirstChild("Code") then
				RoomSkip.NextUngeneratedRoom.Entrances.NormalDoor.Lock.Main.RemoteFunction:InvokeServer(RoomSkip.Password.Code:FindFirstChildOfClass("SurfaceGui"):FindFirstChildOfClass("TextLabel").Text)
			end
		end
	end
end)

game.UserInputService.InputBegan:Connect(function(Input)
	if Input.KeyCode == Enum.KeyCode.P then
		RoomSkip.DoorRoot = nil RoomSkip.DoorRootPrompt = nil GetNextUngeneratedRoom() TeleportToDoor()
	end
end)

