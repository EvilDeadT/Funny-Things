local Player = game.Players.LocalPlayer
local Character = Player.Character
local CurrentCamera = game.Workspace.CurrentCamera

local GameplayFolder = game.Workspace.GameplayFolder
local RoomsFolder = GameplayFolder.Rooms

local OpenedRooms = {"Start"}
local NextUngeneratedRoom = nil
local DoorCollisionPart = nil
local DoorRoot = nil
local DoorRootPrompt = nil

function GetNextUngeneratedRoom()
	local RoomsInExitValue = {}
	for _, Room in RoomsFolder:GetChildren() do
		if Room:FindFirstChild("Entrances") then
			if Room.Entrances:FindFirstChild("NormalDoor") then
				if Room.Entrances.NormalDoor:FindFirstChild("Exit") then
					local ExitRoom = Room.Entrances.NormalDoor.Exit.Value
					if ExitRoom ~= nil then
						if ExitRoom.Parent ~= nil then
							table.insert(RoomsInExitValue, ExitRoom)
						end
					end
				end
			end
		end
	end

	for _, Room in RoomsFolder:GetChildren() do
		if table.find(RoomsInExitValue, Room) == nil and Room:GetAttribute("Room") then
			NextUngeneratedRoom = Room
		end
	end
end

function OpenLockedRoom(LockedRoom, OpenItem, OpenItemType)
	print("Door has locked by "..OpenItemType)
	if OpenItem ~= nil then
		local Prompt = OpenItem:FindFirstChildWhichIsA("ProximityPrompt", true)
		if Prompt == nil then
			print("ERROR | "..OpenItemType.." has not ProximityPrompt in "..LockedRoom.Name)
		else
			Prompt.RequiresLineOfSight = false

			local UncollisionBox = Instance.new("Part", game.Workspace)
			UncollisionBox.Transparency = 0.5
			UncollisionBox.Anchored = true
			UncollisionBox.CanCollide = false
			UncollisionBox.CastShadow = false
			UncollisionBox.Size = Vector3.new(8, 8, 8)
			UncollisionBox.Position = OpenItem.Parent.Position

			local PartsWithCollision = {}
			for _, Part in game.Workspace:GetPartsInPart(UncollisionBox) do
				if Part.CanCollide == true and Part.Parent ~= game.Players.LocalPlayer.Character then
					table.insert(PartsWithCollision, Part)
					Part.CanCollide = false
				end
			end

			local TemporaryFloor = Instance.new("Part", LockedRoom)
			TemporaryFloor.Name = "TemporaryFloor"
			TemporaryFloor.Transparency = 0.5
			TemporaryFloor.Anchored = true
			TemporaryFloor.CanCollide = true
			TemporaryFloor.CastShadow = false
			TemporaryFloor.Size = Vector3.new(8, 1, 8)
			TemporaryFloor.Position = Character.HumanoidRootPart.Position + Vector3.new(0, -4, 0)

			task.wait(15)

			for _, Part in PartsWithCollision do
				Part.CanCollide = true
			end
		end
	end
end

function TeleportToDoor()
  if NextUngeneratedRoom ~= nil then
		if NextUngeneratedRoom.Parent == RoomsFolder then
			if NextUngeneratedRoom:FindFirstChild("Entrances") then
				if NextUngeneratedRoom.Entrances:FindFirstChild("NormalDoor") then
					if NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("Root") then
						if NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("CollisionPart") then
							NextUngeneratedRoom.Entrances.NormalDoor.CollisionPart.CanCollide = false
						end
						
						DoorRoot = NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("Root")
						DoorCollisionPart = NextUngeneratedRoom.Entrances.NormalDoor:FindFirstChild("CollisionPart")

						local Keycard = nil
						local Password = nil
						local RidgeKeycard = nil
						for _, LockedRoom in RoomsFolder:GetChildren() do
							Keycard = LockedRoom:FindFirstChild("NormalKeyCard", true)
							if Keycard ~= nil then
								--OpenLockedRoom(LockedRoom, Keycard, "Keycard")
								break
							end
						end
						if Keycard == nil and Password == nil and RidgeKeycard == nil then
							Character.HumanoidRootPart.CFrame = DoorCollisionPart.CFrame + Vector3.new(0, 1, 0)

							DoorRootPrompt = DoorRoot:FindFirstChildWhichIsA("ProximityPrompt", true)
							if DoorRootPrompt == nil then
								print("ERROR | DoorRoot has not ProximityPrompt in Entrances Door in"..NextUngeneratedRoom.Name)
							end
						end
					end
				end
			end
		end
	end
end

game:GetService("RunService").RenderStepped:Connect(function()
	if DoorRoot ~= nil and DoorRootPrompt ~= nil then
		DoorRoot.CFrame = CFrame.new(
			CurrentCamera.CFrame.Position + CurrentCamera.CFrame.LookVector * 7
		) * CFrame.fromOrientation(0, 0, 0)
		DoorRootPrompt.MaxActivationDistance = 100
		DoorRootPrompt:InputHoldBegin()
		DoorRootPrompt:InputHoldEnd()
	end
end)

GetNextUngeneratedRoom()
TeleportToDoor()

game.UserInputService.InputBegan:Connect(function(Input)
	if Input.KeyCode == Enum.KeyCode.P then
		DoorRoot = nil
		DoorRootPrompt = nil
		GetNextUngeneratedRoom()
		TeleportToDoor()
	end
end)
