function GetNextUngeneratedRoom()
	local RoomsInExitValue = {}
	for _, Room in Main.RoomsFolder:GetChildren() do
		if Room:FindFirstChild("Entrances") then
			for PressureDoorName, PressureDoor in RoomSkip.PressureDoors do
				local Door = Room.Entrances:FindFirstChild(PressureDoorName)
				if Door ~= nil then
					if Door:FindFirstChild("Exit") then
						if Door.Exit:IsA("ObjectValue") then
							local ExitRoom = Door.Exit.Value
							if ExitRoom ~= nil then
								if ExitRoom.Parent ~= nil then
									table.insert(RoomsInExitValue, ExitRoom)
								end
							end
						end
					end
				end
			end
		end
	end

	for _, Room in Main.RoomsFolder:GetChildren() do
		if table.find(RoomsInExitValue, Room) == nil and Room:GetAttribute("Room") then
			RoomSkip.NextUngeneratedRoom = Room
		end
	end
end

function RoomStats()
	if RoomSkip.NextUngeneratedRoom ~= nil then
		if RoomSkip.NextUngeneratedRoom.Parent == Main.RoomsFolder then
			if RoomSkip.NextUngeneratedRoom:FindFirstChild("Entrances") then
				for PressureDoorName, PressureDoor in RoomSkip.PressureDoors do
					local Door = RoomSkip.NextUngeneratedRoom.Entrances:FindFirstChild(PressureDoorName)
					local OriginalDoor = Door
					if Door ~= nil then
						if PressureDoor.DoubleDoor then
							if not Door:FindFirstChild(PressureDoor.DoorOfDoubleDoor) then
								print("ERROR | Double Door '"..PressureDoorName.."' has not single door '"..PressureDoor.DoorOfDoubleDoor.."' in room '"..RoomSkip.NextUngeneratedRoom.Name.."'")
							else
								local MinY = nil
								for _, NormalDoor in Door:GetChildren() do
									if NormalDoor.Name == PressureDoor.DoorOfDoubleDoor then
										if MinY == nil then
											Door = NormalDoor
										else
											if MinY < NormalDoor.WorldPivot.Position.Y then
												Door = NormalDoor
											end
										end
										MinY = NormalDoor.WorldPivot.Position.Y
									end
								end
							end
						end

						local OpenValue = Door:WaitForChild("OpenValue")
						if OpenValue == nil then
							print("ERROR | Door '"..PressureDoorName.."'' has not 'OpenValue' in room '"..RoomSkip.NextUngeneratedRoom.Name.."'")
						else
							if not OpenValue:IsA("BoolValue") then
								print("ERROR | Door '"..PressureDoorName.."'' has 'OpenValue' but it is not BoolValue in room '"..RoomSkip.NextUngeneratedRoom.Name.."'")
							else
								OpenValue:GetPropertyChangedSignal("Value"):Once(function()
									if OpenValue.Value == true and Script.Action ~= "RoomSkip Start" then
										ClearAllStats()
									end
								end)
							end
						end

						local DoorRoot = Door
						local DoorRootPrompt = nil
						local DoorCollisionPart = Door
						local DoorTouchPart = Door
						local Enter = OriginalDoor:FindFirstChild("Enter")
						local Exit = OriginalDoor:FindFirstChild("Exit")

						if PressureDoor.Root == nil then
							DoorRoot = nil
						else
							for _, RootPath in PressureDoor.Root do
								DoorRoot = DoorRoot:FindFirstChild(RootPath)
							end
						end

						if DoorRoot ~= nil then
							DoorRootPrompt = DoorRoot:FindFirstChildWhichIsA("ProximityPrompt")
						end

						if PressureDoor.CollisionPart == nil then
							DoorCollisionPart = nil
						else
							for _, CollisionPartPath in PressureDoor.CollisionPart do
								DoorCollisionPart = DoorCollisionPart:FindFirstChild(CollisionPartPath)
							end
						end

						if PressureDoor.TouchPart == nil then
							DoorTouchPart = nil
						else
							for _, TouchPartPath in PressureDoor.TouchPart do
								DoorTouchPart = DoorTouchPart:FindFirstChild(TouchPartPath)
							end
						end

						if not Enter:IsA("ObjectValue") then
							Enter = nil
						end

						if not Exit:IsA("ObjectValue") then
							Exit = nil
						end

						for _, LockedRoom in Main.RoomsFolder:GetChildren() do
							RoomSkip.Keycard = LockedRoom:FindFirstChild("NormalKeyCard", true)
							if RoomSkip.Keycard == nil then
								RoomSkip.Keycard = LockedRoom:FindFirstChild("RidgeKeyCard", true)
							end
							RoomSkip.Password = LockedRoom:FindFirstChild("PasswordPaper", true)
							if RoomSkip.Keycard ~= nil then
								if RoomSkip.Keycard.Parent ~= nil then
									if RoomSkip.Keycard.Parent:IsA("BasePart") then
										RoomSkip.KeycardParentPartCFrame = RoomSkip.Keycard.Parent.CFrame
									end
								end
								if RoomSkip.Keycard:FindFirstChild("ProxyPart") then
									if RoomSkip.Keycard.ProxyPart:IsA("BasePart") then
										RoomSkip.KeycardProxyPart = RoomSkip.Keycard.ProxyPart
									end
									if RoomSkip.Keycard.ProxyPart:FindFirstChildWhichIsA("ProximityPrompt") then
										RoomSkip.KeycardProxyPartPrompt = RoomSkip.Keycard.ProxyPart:FindFirstChildWhichIsA("ProximityPrompt")
									end
								end
								break
							elseif RoomSkip.Password ~= nil then
								if RoomSkip.Password:FindFirstChild("Code") then
									if RoomSkip.Password.Code:FindFirstChildWhichIsA("SurfaceGui") then
										if RoomSkip.Password.Code:FindFirstChildWhichIsA("SurfaceGui"):FindFirstChildWhichIsA("TextLabel") then
											RoomSkip.PasswordCode = RoomSkip.Password.Code:FindFirstChildWhichIsA("SurfaceGui"):FindFirstChildWhichIsA("TextLabel").Text
										end
									end
								end
								break
							end
						end

						if RoomSkip.Keycard ~= nil or RoomSkip.Password ~= nil then
							local LockMain = Door
							local LockPrompt = Door
							local LockRemoteFunction = Door

							if PressureDoor.LockMain == nil then
								LockMain = nil
							else
								for _, LockMainPath in PressureDoor.LockMain do
									LockMain = LockMain:FindFirstChild(LockMainPath)
								end
							end

							if PressureDoor.LockPrompt == nil then
								LockPrompt = nil
							else
								for _, LockPromptPath in PressureDoor.LockPrompt do
									LockPrompt = LockPrompt:FindFirstChild(LockPromptPath)
								end
								if LockPrompt ~= nil then
									LockPrompt = LockPrompt:FindFirstChildWhichIsA("ProximityPrompt")
								end
							end

							if PressureDoor.LockRemoteFunction == nil then
								LockRemoteFunction = nil
							else
								for _, LockRemoteFunctionPath in PressureDoor.LockRemoteFunction do
									LockRemoteFunction = LockRemoteFunction:FindFirstChild(LockRemoteFunctionPath)
								end
								if LockRemoteFunction ~= nil then
									LockRemoteFunction = LockRemoteFunction:FindFirstChildWhichIsA("RemoteFunction")
								end
							end

							RoomSkip.LockMain = LockMain
							RoomSkip.LockPrompt = LockPrompt
							RoomSkip.LockRemoteFunction = LockRemoteFunction
						end
						if Exit ~= nil then
							if Exit.Value.Name == "ModifierEnding" then
								if Exit.Value:FindFirstChild("Interactables") then
									if Exit.Value.Interactables:FindFirstChild("EndRun") then
										if Exit.Value.Interactables.EndRun:FindFirstChild("Highlight") then
											RoomSkip.EndRunButtonHighlight = Exit.Value.Interactables.EndRun.Highlight
											RoomSkip.EndRunButtonHighlightCFrame = Exit.Value.Interactables.EndRun.Highlight.CFrame
											if Exit.Value.Interactables.EndRun.Highlight:FindFirstChildWhichIsA("ProximityPrompt") then
												RoomSkip.EndRunButtonHighlightPrompt = Exit.Value.Interactables.EndRun.Highlight:FindFirstChildWhichIsA("ProximityPrompt")
											end
										end
									end
								end
							end
						end

						RoomSkip.DoorRoot = DoorRoot
						RoomSkip.DoorRootPrompt = DoorRootPrompt
						RoomSkip.DoorCollisionPartCFrame = DoorCollisionPart.CFrame
						RoomSkip.DoorTouchPart = DoorTouchPart
						RoomSkip.Enter = Enter
						RoomSkip.Exit = Exit
					end
				end
			end
		end
	end
end

function TeleportToDoor()
	Script.Action = "RoomSkip Start"
	GetNextUngeneratedRoom()
	RoomStats()
end

function UnCollisionAll(TeleportCFrame)
	for _, Part in Main.UnCollisionBoxCollisionParts do
		if Part ~= nil then
			if Part.Parent ~= nil then
				if Part:IsA("BasePart") and Part.Name ~= "CollisionPart" then
					Part.CanCollide = true
				end
			end
		end
	end

	local TemporaryFloor = game.Workspace:FindFirstChild("TemporaryFloor")
	if TemporaryFloor == nil then
		TemporaryFloor = Instance.new("Part", game.Workspace)
		TemporaryFloor.Name = "TemporaryFloor"
		TemporaryFloor.Transparency = 0.5
		TemporaryFloor.Anchored = true
		TemporaryFloor.CanCollide = true
		TemporaryFloor.CastShadow = false
		TemporaryFloor.Size = Vector3.new(8, 1, 8)
	end

	local UncollisionBox = game.Workspace:FindFirstChild("UncollisionBox")
	if UncollisionBox == nil then
		UncollisionBox = Instance.new("Part", game.Workspace)
		UncollisionBox.Name = "UncollisionBox"
		UncollisionBox.Transparency = 0.5
		UncollisionBox.Anchored = true
		UncollisionBox.CanCollide = false
		UncollisionBox.CastShadow = false
		UncollisionBox.Size = Vector3.new(8, 8, 8)
	end

	UncollisionBox.CFrame = TeleportCFrame
	TemporaryFloor.CFrame = TeleportCFrame + Vector3.new(0, -4, 0)

	for _, Part in game.Workspace:GetPartsInPart(UncollisionBox) do
		if Part.Parent ~= game.Players.LocalPlayer.Character and Part:IsA("BasePart") then
			if Part.CanCollide == true and Part ~= TemporaryFloor then
				Part.CanCollide = false
				table.insert(Main.UnCollisionBoxCollisionParts, Part)
			end
		end
	end
end

game:GetService("RunService").RenderStepped:Connect(function()
	local ScriptActionNow = "Idle"

	for _, LocalEntity in Script.DeleteLocalEntities do
		if LocalEntity == "WitchingHour" and game.Workspace:FindFirstChild("WitchingHour") then
			game.Workspace.WitchingHour:Destroy()
			print(LocalEntity.." killed :)")
		end
	end

	if Script.Mode == "RoomSkip" then
		if RoomSkip.Exit ~= nil then
			if string.find(RoomSkip.Exit.Value.Name, "PipeBoardPuzzle") then
				print("IT'S!! PUZZLE!! TIME!!!")
				if RoomSkip.Exit.Value:FindFirstChild("Entrances") then
					for PressureDoorName, PressureDoor in RoomSkip.PressureDoors do
						local Door = RoomSkip.Exit.Value.Entrances:FindFirstChild(PressureDoorName)
						if Door ~= nil then
							if Door:FindFirstChild("CollisionPart") then
								if Door.CollisionPart:IsA("BasePart") then
									Main.CharacterRoot.CFrame = Door.CollisionPart.CFrame + Vector3.new(0, 1, 0)
								end
							end
						end
					end
				end
				ClearAllStats(true)
			elseif RoomSkip.Exit.Value.Name == "ModifierEnding" then
				if RoomSkip.EndRunButtonHighlight ~= nil and RoomSkip.EndRunButtonHighlightPrompt ~= nil then
					ScriptActionNow = "Run Finish"
					RoomSkip.EndRunButtonHighlight.CFrame = CFrame.new(
						Main.CurrentCamera.CFrame.Position + Main.CurrentCamera.CFrame.LookVector * 7
					) * CFrame.fromOrientation(0, 0, 0)
					RoomSkip.EndRunButtonHighlightPrompt.MaxActivationDistance = 100
					RoomSkip.EndRunButtonHighlightPrompt:InputHoldBegin()
					RoomSkip.EndRunButtonHighlightPrompt:InputHoldEnd()

					local TeleportCFrame = RoomSkip.EndRunButtonHighlightCFrame
					UnCollisionAll(TeleportCFrame)
					Main.CharacterRoot.CFrame = TeleportCFrame
				end
			end
		end

		if ScriptActionNow ~= "Run Finish" then
			if RoomSkip.DoorRoot ~= nil and RoomSkip.DoorRootPrompt ~= nil then
				ScriptActionNow = "Open ProgressDoor Root"
				RoomSkip.DoorRoot.CFrame = CFrame.new(
					Main.CurrentCamera.CFrame.Position + Main.CurrentCamera.CFrame.LookVector * 7
				) * CFrame.fromOrientation(0, 0, 0)
				RoomSkip.DoorRootPrompt.MaxActivationDistance = 100
				RoomSkip.DoorRootPrompt.Enabled = true
				RoomSkip.DoorRootPrompt:InputHoldBegin()
				RoomSkip.DoorRootPrompt:InputHoldEnd()
			end

			if RoomSkip.Keycard ~= nil then
				if game.Players.LocalPlayer.PlayerGui.Main.Health.AuxItems.NormalKeyCard.Visible == false then
					if RoomSkip.KeycardParentPartCFrame ~= nil and RoomSkip.KeycardProxyPart ~= nil and RoomSkip.KeycardProxyPartPrompt ~= nil then
						ScriptActionNow = "Pick Keycard"
						RoomSkip.KeycardProxyPart.CFrame = CFrame.new(
							Main.CurrentCamera.CFrame.Position + Main.CurrentCamera.CFrame.LookVector * 7
						) * CFrame.fromOrientation(0, 0, 0)
						RoomSkip.KeycardProxyPartPrompt.MaxActivationDistance = 100
						RoomSkip.KeycardProxyPartPrompt.RequiresLineOfSight = false
						RoomSkip.KeycardProxyPartPrompt:InputHoldBegin()
						RoomSkip.KeycardProxyPartPrompt:InputHoldEnd()

						local TeleportCFrame = RoomSkip.KeycardParentPartCFrame
						UnCollisionAll(TeleportCFrame)
						Main.CharacterRoot.CFrame = TeleportCFrame	
					end
				else
					if RoomSkip.LockMain ~= nil and RoomSkip.LockPrompt ~= nil then
						ScriptActionNow = "Open ProgressDoor Keycard"
						RoomSkip.KeycardParentPartCFrame = nil
						RoomSkip.KeycardProxyPart = nil
						RoomSkip.KeycardProxyPartPrompt = nil

						RoomSkip.LockMain.CFrame = CFrame.new(
							Main.CurrentCamera.CFrame.Position + Main.CurrentCamera.CFrame.LookVector * 7
						) * CFrame.fromOrientation(0, 0, 0)
						RoomSkip.LockPrompt.MaxActivationDistance = 100
						RoomSkip.LockPrompt.HoldDuration = 0
						RoomSkip.LockPrompt:InputHoldBegin()
						RoomSkip.LockPrompt:InputHoldEnd()
					end
				end
			else
				if RoomSkip.LockRemoteFunction ~= nil and RoomSkip.PasswordCode ~= nil then
					ScriptActionNow = "Open ProgressDoor Password"
					RoomSkip.LockRemoteFunction:InvokeServer(RoomSkip.PasswordCode)
				end
			end

			if RoomSkip.DoorTouchPart ~= nil then
				print("Touch part. Still in progress")
				ClearAllStats(true)
			end
			if string.find(ScriptActionNow, "Open ProgressDoor") and Main.CharacterRoot ~= nil and RoomSkip.DoorCollisionPartCFrame ~= nil then
				local TeleportCFrame = RoomSkip.DoorCollisionPartCFrame + Vector3.new(0, -4, 0)
				UnCollisionAll(TeleportCFrame)
				Main.CharacterRoot.CFrame = TeleportCFrame
				game.ReplicatedStorage.Events.ZoneChange:FireServer(RoomSkip.NextUngeneratedRoom)
			end
		end
	end

	Script.Action = ScriptActionNow
end)

game.UserInputService.InputBegan:Connect(function(Input)
	if Script.Mode == "RoomSkip" and Script.Action == "Idle" then
		if Input.KeyCode == Enum.KeyCode.P then
			TeleportToDoor()
		end
	end
	if Input.KeyCode == Enum.KeyCode.Z then
		if RoomSkip.NextUngeneratedRoom == nil then
			print("WARNING | No NextUngeneratedRoom")
		end
		ClearAllStats(true)
	end
end)
