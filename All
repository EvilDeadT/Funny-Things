function GetNextUngeneratedRoom()
	local RoomsInExitValue = {}
	for _, Room in Main.RoomsFolder:GetChildren() do
		if Room:FindFirstChild("Entrances") then
			if Room.Entrances:FindFirstChild("NormalDoor") then
				if Room.Entrances.NormalDoor:FindFirstChild("Exit") then
					local ExitRoom = Room.Entrances.NormalDoor.Exit.Value
					if ExitRoom ~= nil then
						if ExitRoom.Parent ~= nil then
							table.insert(RoomsInExitValue, ExitRoom)
						end
					end
				end
			end
		end
	end

	for _, Room in Main.RoomsFolder:GetChildren() do
		if table.find(RoomsInExitValue, Room) == nil and Room:GetAttribute("Room") then
			RoomSkip.NextUngeneratedRoom = Room
		end
	end
end

function RoomStats()
	if RoomSkip.NextUngeneratedRoom ~= nil then
		if RoomSkip.NextUngeneratedRoom.Parent == Main.RoomsFolder then
			if RoomSkip.NextUngeneratedRoom:FindFirstChild("Entrances") then
				for PressureDoorName, PressureDoor in RoomSkip.Doors do
					local Door = RoomSkip.NextUngeneratedRoom.Entrances:FindFirstChild(PressureDoorName)
					local OriginalDoor = Door
					if Door ~= nil then
						if PressureDoor.DoubleDoor then
							if not Door:FindFirstChild(PressureDoor.DoorOfDoubleDoor) then
								print("ERROR | Double Door '"..PressureDoorName.."' has not single door '"..PressureDoor.DoorOfDoubleDoor.."' in room '"..RoomSkip.NextUngeneratedRoom.."'")
							else
								local MinY = nil
								for _, NormalDoor in Door:GetChildren() do
									if NormalDoor.Name == PressureDoor.DoorOfDoubleDoor then
										if MinY == nil then
											Door = NormalDoor
										else
											if MinY < NormalDoor.WorldPivot.Position.Y then
												Door = NormalDoor
											end
										end
										MinY = NormalDoor.WorldPivot.Position.Y
									end
								end
							end

							local DoorRoot = Door
							local DoorCollisionPart = Door
							local DoorTouchPart = Door
							local DoorPrompt = nil
							local Enter = OriginalDoor:FindFirstChild("Enter")
							local Exit = OriginalDoor:FindFirstChild("Exit")

							for _, RootPath in PressureDoor.Root do
								DoorRoot = DoorRoot:FindFirstChild(RootPath)
							end

							for _, CollisionPartPath in PressureDoor.CollisionPart do
								DoorCollisionPart = DoorCollisionPart:FindFirstChild(CollisionPartPath)
							end

							for _, TouchPartPath in PressureDoor.TouchPart do
								DoorTouchPart = DoorTouchPart:FindFirstChild(TouchPartPath)
							end

							DoorPrompt = DoorRoot:FindFirstChildWhichIsA("ProximityPrompt")

							if not Enter:IsA("ObjectValue") then
								Enter = nil
							end

							if not Exit:IsA("ObjectValue") then
								Exit = nil
							end

							for _, LockedRoom in Main.RoomsFolder:GetChildren() do
								RoomSkip.Keycard = LockedRoom:FindFirstChild("NormalKeyCard", true)
								if RoomSkip.Keycard == nil then
									RoomSkip.Keycard = LockedRoom:FindFirstChild("RidgeKeyCard", true)
								end
								RoomSkip.Password = LockedRoom:FindFirstChild("PasswordPaper", true)
								if RoomSkip.Keycard ~= nil then
									break
								elseif RoomSkip.Password ~= nil then
									if RoomSkip.Password:FindFirstChild("Code") then
										if RoomSkip.Password:FindFirstChildOfClass("SurfaceGui") then
											if RoomSkip.Password.Code:FindFirstChildOfClass("SurfaceGui"):FindFirstChildOfClass("TextLabel") then
												RoomSkip.PasswordCode = RoomSkip.Password.Code:FindFirstChildOfClass("SurfaceGui"):FindFirstChildOfClass("TextLabel").Text
											end
										end
									end
									break
								end
							end

							if RoomSkip.Keycard ~= nil or RoomSkip.Password ~= nil then
								local LockPrompt = nil
								local LockRemoteFunction = nil

								for _, LockPromptPath in PressureDoor.LockPrompt do
									LockPrompt = LockPrompt:FindFirstChild(LockPromptPath)
								end
								if LockPrompt ~= nil then
									LockPrompt:FindFirstChildWhichIsA("ProximityPrompt")
								end

								for _, LockRemoteFunctionPath in PressureDoor.LockRemote do
									LockRemoteFunction = LockRemoteFunction:FindFirstChild(LockRemoteFunctionPath)
								end
								if LockRemoteFunction ~= nil then
									LockRemoteFunction:FindFirstChildWhichIsA("RemoteFunction")
								end

								RoomSkip.LockPrompt = LockPrompt
								RoomSkip.LockRemoteFunction = LockRemoteFunction
							end

							RoomSkip.DoorRoot = DoorRoot
							RoomSkip.DoorCollisionPart = DoorCollisionPart
							RoomSkip.TouchPart = DoorTouchPart
							RoomSkip.DoorPrompt = DoorPrompt
							RoomSkip.Enter = Enter
							RoomSkip.Exit = Exit
						end
					end
				end
			end
		end
	end
end

function TeleportToDoor()
	Script.Action = "RoomSkip Start"
	GetNextUngeneratedRoom()
	RoomStats()
end

game:GetService("RunService").RenderStepped:Connect(function()
	if Script.Mode == "RoomSkip" then
		if (RoomSkip.DoorRoot ~= nil or RoomSkip.DoorTouchPart ~= nil) and RoomSkip.DoorCollisionPart ~= nil then
			if RoomSkip.DoorRootPrompt ~= nil then
				Script.Action = "Open ProgressDoor"
				RoomSkip.DoorRoot.CFrame = CFrame.new(
					Main.CurrentCamera.CFrame.Position + Main.CurrentCamera.CFrame.LookVector * 7
				) * CFrame.fromOrientation(0, 0, 0)
				RoomSkip.DoorRootPrompt.MaxActivationDistance = 100
				RoomSkip.DoorRootPrompt:InputHoldBegin()
				RoomSkip.DoorRootPrompt:InputHoldEnd()
			else
				if RoomSkip.Keycard ~= nil then
					--Script.Action = "Open Keycard ProgressDoor"
				else
					if RoomSkip.LockRemoteFunction ~= nil and RoomSkip.PasswordCode ~= nil then
						Script.Action = "Open Password ProgressDoor"
						RoomSkip.RemoteFunction:InvokeServer(RoomSkip.PasswordCode)
					end
				end
			end
		end
		if string.find(Script.Action, "ProgressDoor") and Main.Character ~= nil and RoomSkip.DoorCollisionPart ~= nil then
			Main.Character.HumanoidRootPart.CFrame = RoomSkip.DoorCollisionPart.CFrame + Vector3.new(0, 1, 0)
		end
	end
end)

game.UserInputService.InputBegan:Connect(function(Input)
	if Script.Mode == "RoomSkip" and Script.Action == "Idle" then
		if Input.KeyCode == Enum.KeyCode.P then
			TeleportToDoor()
		end
	end
end)
